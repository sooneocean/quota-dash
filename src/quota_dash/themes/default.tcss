/* src/quota_dash/themes/default.tcss */
Screen {
    layout: vertical;
    background: $surface;
}

OverviewTable {
    height: auto;
    max-height: 12;
    margin-bottom: 1;
}

DetailPanel {
    height: auto;
}

#detail-grid {
    layout: grid;
    grid-size: 2 2;
    grid-gutter: 1;
}

@media (width < 120) {
    #detail-grid {
        grid-size: 1;
    }
}

HistoryTable {
    height: auto;
    max-height: 10;
    margin-top: 1;
}

Footer {
    dock: bottom;
}
